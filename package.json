{
	"name": "@cloudlayerio/sdk",
	"version": "0.1.0",
	"description": "Official TypeScript/JavaScript SDK for the CloudLayer.io document generation API",
	"license": "Apache-2.0",
	"author": "CloudLayer.io",
	"repository": {
		"type": "git",
		"url": "https://github.com/cloudlayerio/cloudlayerio-js.git"
	},
	"homepage": "https://cloudlayer.io",
	"bugs": {
		"url": "https://github.com/cloudlayerio/cloudlayerio-js/issues"
	},
	"keywords": [
		"cloudlayer",
		"pdf",
		"screenshot",
		"html-to-pdf",
		"url-to-pdf",
		"document-generation",
		"api",
		"sdk"
	],
	"engines": {
		"node": ">=18.13.0"
	},
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE",
		"CHANGELOG.md"
	],
	"sideEffects": false,
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"lint": "biome check src/ tests/",
		"lint:fix": "biome check --write src/ tests/",
		"format": "biome format --write src/ tests/",
		"format:check": "biome format src/ tests/",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "npm run build"
	},
	"publishConfig": {
		"access": "public"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@types/node": "^25.5.0",
		"@vitest/coverage-v8": "^4.1.0",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3",
		"vitest": "^4.1.0"
	}
}
